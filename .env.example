# Datos
NPS_LENS_DATA_DIR=./data
NPS_LENS_KNOWLEDGE_DIR=./knowledge

# App / UI
NPS_LENS_DEFAULT_SERVICE_ORIGIN=BBVA México
NPS_LENS_DEFAULT_SERVICE_ORIGIN_N1=ENTERPRISE WEB
NPS_LENS_UI_THEME_MODE=light
NPS_LENS_UI_DOWNLOADS_PATH=~/Downloads
NPS_LENS_UI_HELIX_BASE_URL=https://itsmhelixbbva-smartit.onbmc.com/smartit/app/#/incidentPV/
NPS_LENS_UI_TOUCHPOINT_SOURCE=domain_touchpoint
NPS_LENS_UI_MIN_SIMILARITY=0.25
NPS_LENS_UI_MAX_DAYS_APART=10
NPS_LENS_UI_MIN_N_OPPORTUNITIES=200
NPS_LENS_UI_MIN_N_CROSS_COMPARISONS=30
NPS_LENS_PORT=8617

# Contexto (controlado por .env)
# Fuente única de verdad para combos/valores permitidos.
#
# service_origin_buug (upstream) => Service origin (UI)
NPS_LENS_SERVICE_ORIGIN_BUUG=BBVA México, BBVA España, BBVA Colombia, BBVA Perú, BBVA Argentina

# service_origin_n1: mapping por Service origin.
# Formato recomendado: JSON dict.
NPS_LENS_SERVICE_ORIGIN_N1={"BBVA México": ["ENTERPRISE WEB", "MOBILE ENTERPRISE"], "BBVA España": ["ENTERPRISE MOBILE CHANNEL", "ENTERPRISES CHANNEL"], "BBVA Colombia": ["ENTERPRISE MOBILE (GEMA)", "ENTERPRISE WEB CHANNEL"], "BBVA Perú": ["ENTERPRISE BANKING CANALES WEB & MOBILE"], "BBVA Argentina": ["AR44 PLATAFORMA SENDA ARG", "AR46 GEMA ARG"]}

# service_origin_n2_map: catálogo opcional por combinación BUUG + N1.
# - Si lo dejas vacío, la UI permitirá gestionar N2 de forma dinámica.
NPS_LENS_SERVICE_ORIGIN_N2_MAP={}

# Plantilla PPT corporativa (opcional)
# Si no se define, el export usa la plantilla por defecto/fallback.
NPS_LENS_PPT_TEMPLATE=

# OpenAI / LLM (opcional)
# Solo es necesario si se habilitan flujos LLM.
NPS_LENS_OPENAI_API_KEY=
NPS_LENS_OPENAI_MODEL=gpt-4o-mini
NPS_LENS_OPENAI_TEMPERATURE=0.2
NPS_LENS_OPENAI_TIMEOUT_S=60

# Profiling (opcional, 1 para activar)
NPS_LENS_PROFILE=0

# Logging
NPS_LENS_LOG_LEVEL=INFO
